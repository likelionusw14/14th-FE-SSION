function solution(numer1, denom1, numer2, denom2) {
    let x = numer1 * denom2 + numer2 * denom1;
    let y = denom1 * denom2;

    for (let i = 2; i <= x; i++) {
        if (x % i === 0 && y % i === 0) {
            x /= i;
            y /= i;
            i = 1;  
        }
    }

    return [x, y];
}